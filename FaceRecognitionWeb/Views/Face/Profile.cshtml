@{
    ViewData["Title"] = "个人信息";
    var user = ViewBag.User;
    var faceImage = user?.GetProperty("face_image")?.GetString();
    var username = user?.GetProperty("username")?.GetString();
    var createTime = user?.GetProperty("create_time")?.GetString();
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3>个人信息</h3>
                    <div>
                        <a asp-action="Users" class="btn btn-sm btn-outline-secondary">返回</a>
                        <a asp-action="Logout" class="btn btn-sm btn-outline-danger">退出</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    else
                    {
                        <div class="row">
                            <div class="col-md-5 text-center">
                                <div class="mb-3">
                                    <label class="form-label">注册人脸图像</label>
                                    <div class="border rounded p-2">
                                        @if (!string.IsNullOrEmpty(faceImage))
                                        {
                                            <img src="data:image/jpeg;base64,@faceImage" alt="人脸图像" class="img-fluid" style="max-height: 300px;" />
                                        }
                                        else
                                        {
                                            <div class="text-muted py-5">暂无图像</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label class="form-label">昵称</label>
                                    <input type="text" class="form-control" value="@username" readonly />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">用户ID</label>
                                    <input type="text" class="form-control" value="@user?.GetProperty("id")" readonly />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">注册时间</label>
                                    <input type="text" class="form-control" value="@createTime" readonly />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
